# Dev image for the frontend: runs the Vite dev server with HMR.
# Source is bind-mounted at runtime (see docker-compose.override.yml), so we only
# need deps baked in. The prod image lives in Dockerfile.frontend (nginx).
FROM node:20-slim

WORKDIR /app
COPY package*.json ./
RUN npm ci

# Source is mounted over /app at runtime; copy here only as a fallback.
COPY . .

EXPOSE 5173
# --host exposes the dev server outside the container.
CMD ["npm", "run", "dev", "--", "--host"]
